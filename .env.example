# ===== 百炼平台 =====
# 阿里云百炼 API Key，获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxx

# ===== Chinese-CLIP（本地） =====
# 无需 API Key，模型首次加载自动下载
CHINESE_CLIP_MODEL=OFA-Sys/chinese-clip-vit-base-patch16

# ===== Chroma（本地） =====
# 无需额外配置，默认持久化到 ./chroma_data/

# ===== MinIO（本地开发示例） =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123456
MINIO_SECURE=false
MINIO_BUCKET=shopping-qna

# ===== LangSmith（可选） =====
LANGCHAIN_API_KEY=ls_xxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=ShoppingQnA-Bailian

# ===== 图数据库（后续启用） =====
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=yourpassword
